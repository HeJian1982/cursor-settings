{
    "name": "memory",
    "description": "内存使用（总/已用/可用）",
    "keywords": ["内存", "memory", "ram", "内存使用"],
    "kind": "shell",
    "command": "powershell -NoProfile -Command \"$os=Get-CimInstance Win32_OperatingSystem; [PSCustomObject]@{TotalGB=[math]::Round($os.TotalVisibleMemorySize/1MB,1); FreeGB=[PSCustomObject]@{V=[math]::Round($os.FreePhysicalMemory/1MB,1)}; UsedGB=[math]::Round(($os.TotalVisibleMemorySize-$os.FreePhysicalMemory)/1MB,1); PctUsed=[math]::Round((($os.TotalVisibleMemorySize-$os.FreePhysicalMemory)*100)/$os.TotalVisibleMemorySize,1)} | Format-List | Out-String\""
}
